<mujoco model="rada">
  <compiler inertiafromgeom="auto" angle="degree" balanceinertia="true" boundmass="0.001" boundinertia=".0001" meshdir=".." texturedir=".."/>
  <size njmax="1000" nconmax="400" nuser_jnt="1"/>
  <option timestep="0.01"  gravity="0 0 0"/>
  
  <visual>
    <headlight diffuse="1 1 1"/>
    <!--scale actuatorwidth=".075"/-->
  </visual>

<default>
<default class="upperarm_muscle">
    <tendon rgba="0.95 0.3 0.3 41" width="0.005"/>
    <muscle ctrllimited="true" ctrlrange="0 1" />
    <joint limited="true" damping="1.05" armature="1e-4" stiffness="0" user="1e-9"/>
    <site size="0.01" rgba="0.0 0.3 0.3 1" />
</default>
<default class="wrap">
    <geom group="0" rgba="0.19 0.83 0.78 0.2"/>
</default>
</default>

  <worldbody>
    <body name="humerus" pos="0 0 0.1" childclass="upperarm_muscle">
        <site name="ee_site_target"   pos=" .0 0.02  0" rgba="1 0 0 1"/>
        <geom mesh="humerus_geom_1_humerus" name="humerus_geom_1" type="mesh"/>
        
        <site name="extensor_init" pos="-.01 -0.05 0"/>
        <site name="TRI_cylinder_TRImed_4_sidesite" pos="-0.00964741 -0.30644 -0.0103312" class="upperarm_muscle"/>
        <geom class="wrap" name="TRI_cylinder" pos="0.0028 -0.2919 -0.0119" quat="0.994531 -0.0700249 0.0022946 0.0774514" size="0.016 0.05" type="cylinder" rgba="1 0 0 0"/>        

        <site name="flexor_init" size="0.01" pos=".02 -0.15 0" rgba=".8 0 0 1"/>        
        <geom class="wrap" name="ElbowBICBRD_ellipsoid_wrap" pos="0.0019 -0.289 -0.014" quat="0.995524 -0.0630586 0.0695464 0.0108747" size="0.015 0.1" type="cylinder"/>        
        <site name="Elbow_BIC_BRD_ellipsoid_BICshort_5_sidesite" pos="0.0158403 -0.275971 -0.0182235"/>
                    
        <body name="ulna" pos="0.0061 -0.2904 -0.0123">
            <joint axis="0.0494004 0.0366003 0.998108" name="elbow_flexion" pos="0 0 0" range="5 130" user="1.05676"/>
            <geom mesh="ulna_geom_1_ulna" name="ulna_geom_1" type="mesh"/>
            
            <site name="extensor_end" pos="-.01 -0.05 0"/>
            <site name="flexor_end"   pos=" .02 -0.02  0"/>
            <site name="ee_site"   pos=" .02 -0.02  0"/>
            
            
            <body name="radius" pos="0.0004 -0.0115 0.02">
                <geom mesh="radius_geom_1_radius" name="radius" type="mesh"/>
            </body>    
            
        </body>            
    </body>

  </worldbody>


<tendon>
    <spatial name="flexor_tendon" class="upperarm_muscle">
        <site site="flexor_init"/>
        <!--geom geom="TRI_cylinder" sidesite="TRI_cylinder_TRImed_4_sidesite"/-->
        <geom geom="ElbowBICBRD_ellipsoid_wrap" sidesite="Elbow_BIC_BRD_ellipsoid_BICshort_5_sidesite"/>
        <site site="flexor_end"/>
    </spatial>

    <spatial name="extensor_tendon" class="upperarm_muscle">
        <site site="extensor_init"/>
        <geom geom="TRI_cylinder" sidesite="TRI_cylinder_TRImed_4_sidesite"/>
        <site site="extensor_end"/>
    </spatial>
</tendon>

<actuator>
    <!-- biasrpm defines actuator properties -->
    <!--general name="flexor" tendon="flexor_tendon" biasprm="0.297699 1.6 421.718 1 0 1.8 10 1.1404 1.4 0" class="upperarm_muscle" gainprm="0.297699 1.6 421.718 1 0 1.8 10 1.1404 1.4 0" lengthrange="0.314572 0.480222"/>
    <general name="extensor" tendon="extensor_tendon" biasprm="0.692589 1.5232 670.069 1 0 1.8 10 1.87109 1.4 0" class="upperarm_muscle" gainprm="0.692589 1.5232 670.069 1 0 1.8 10 1.87109 1.4 0" lengthrange="0.244705 0.39348"/-->    
    <muscle tendon="flexor_tendon"   name="flexor"   force="3000" lengthrange="0.15 0.2"/>
    <muscle tendon="extensor_tendon" name="extensor" force="3000" lengthrange="0.25 0.30"/>
</actuator>

<asset>
	<mesh file="../../myo_sim/meshes/humerus.stl" name="humerus_geom_1_humerus"/>
	<mesh file="../../myo_sim/meshes/ulna.stl" name="ulna_geom_1_ulna"/>
	<mesh file="../../myo_sim/meshes/radius.stl" name="radius_geom_1_radius"/>

</asset>
</mujoco>

